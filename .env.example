# ===========================================
# Portfolio Configuration
# ===========================================

# GitHub username (used for profile, calendar, cards)
VITE_GITHUB_USERNAME="your-github-username"

# Medium username (used for blog feed)
VITE_MEDIUM_USERNAME="your-medium-username"

# Medium profile URL (used for "View All" link)
VITE_MEDIUM_URL="https://medium.com/@your-medium-username"

# ===========================================
# Spotify Integration
# Get these from https://developer.spotify.com/dashboard
# ===========================================
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"
SPOTIFY_REFRESH_TOKEN="your_spotify_refresh_token"

# ===========================================
# View Counter (Vercel KV / Upstash Redis)
# ===========================================
KV_REST_API_URL="your_redis_rest_url"
KV_REST_API_TOKEN="your_redis_rest_token"
